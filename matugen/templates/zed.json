{
  "$schema": "https://zed.dev/schema/themes/v0.1.0.json",
  "name": "Matugen",
  "author": "matugen",
  "themes": [
    {
      "name": "Matugen Dark",
      "appearance": "dark",
      "style": {
        "background": "{{colors.background.default.hex}}",
        "border": "{{colors.outline.default.hex}}",
        "border.variant": "{{colors.outline_variant.default.hex}}",
        "border.focused": "{{colors.primary.default.hex}}",
        "border.selected": "{{colors.secondary.default.hex}}",
        "border.transparent": "{{colors.background.default.hex}}",
        "border.disabled": "{{colors.outline_variant.default.hex}}",
        "elevated_surface.background": "{{colors.surface.default.hex}}",
        "surface.background": "{{colors.surface.default.hex}}",
        "background.appearance": "opaque",

        "text": "{{colors.on_background.default.hex}}",
        "text.muted": "{{colors.on_surface_variant.default.hex}}",
        "text.placeholder": "{{colors.outline.default.hex}}",
        "text.disabled": "{{colors.on_surface_variant.default.hex | set_alpha: 0.5}}",
        "text.accent": "{{colors.primary.default.hex}}",

        "icon": "{{colors.on_surface.default.hex}}",
        "icon.muted": "{{colors.on_surface_variant.default.hex}}",
        "icon.disabled": "{{colors.on_surface_variant.default.hex | set_alpha: 0.5}}",
        "icon.placeholder": "{{colors.outline.default.hex}}",
        "icon.accent": "{{colors.primary.default.hex}}",

        "status_bar.background": "{{colors.surface.default.hex}}",
        "title_bar.background": "{{colors.surface.default.hex}}",
        "toolbar.background": "{{colors.background.default.hex}}",
        "tab_bar.background": "{{colors.surface.default.hex}}",
        "tab.inactive_background": "{{colors.surface.default.hex}}",
        "tab.active_background": "{{colors.primary_container.default.hex}}",

        "editor.background": "{{colors.background.default.hex}}",
        "editor.gutter.background": "{{colors.background.default.hex}}",
        "editor.subheader.background": "{{colors.surface.default.hex}}",
        "editor.active_line.background": "{{colors.surface_variant.default.hex | set_alpha: 0.3}}",
        "editor.highlighted_line.background": "{{colors.surface_variant.default.hex | set_alpha: 0.5}}",
        "editor.line_number": "{{colors.outline.default.hex}}",
        "editor.active_line_number": "{{colors.primary.default.hex}}",
        "editor.invisible": "{{colors.outline.default.hex}}",
        "editor.wrap_guide": "{{colors.outline_variant.default.hex}}",
        "editor.active_wrap_guide": "{{colors.outline.default.hex}}",

        "editor.document_highlight.read_background": "{{colors.primary_container.default.hex | set_alpha: 0.3}}",
        "editor.document_highlight.write_background": "{{colors.primary_container.default.hex | set_alpha: 0.5}}",

        "terminal.background": "{{colors.background.default.hex}}",
        "terminal.foreground": "{{colors.on_background.default.hex}}",
        "terminal.bright_foreground": "{{colors.on_surface.default.hex}}",
        "terminal.dim_foreground": "{{colors.on_surface_variant.default.hex}}",
        "terminal.ansi.black": "{{colors.surface.default.hex}}",
        "terminal.ansi.red": "{{colors.error.default.hex}}",
        "terminal.ansi.green": "{{colors.tertiary.default.hex}}",
        "terminal.ansi.yellow": "{{colors.secondary.default.hex}}",
        "terminal.ansi.blue": "{{colors.primary.default.hex}}",
        "terminal.ansi.magenta": "{{colors.tertiary_fixed_dim.default.hex}}",
        "terminal.ansi.cyan": "{{colors.secondary.default.hex}}",
        "terminal.ansi.white": "{{colors.on_surface.default.hex}}",
        "terminal.ansi.bright_black": "{{colors.outline.default.hex}}",
        "terminal.ansi.bright_red": "{{colors.error.default.hex | set_lightness: 70}}",
        "terminal.ansi.bright_green": "{{colors.tertiary.default.hex | set_lightness: 70}}",
        "terminal.ansi.bright_yellow": "{{colors.secondary.default.hex | set_lightness: 70}}",
        "terminal.ansi.bright_blue": "{{colors.primary.default.hex | set_lightness: 70}}",
        "terminal.ansi.bright_magenta": "{{colors.tertiary_fixed.default.hex}}",
        "terminal.ansi.bright_cyan": "{{colors.secondary_fixed.default.hex}}",
        "terminal.ansi.bright_white": "{{colors.on_surface_variant.default.hex}}",

        "link_text.hover": "{{colors.primary.default.hex}}",

        "conflict": "{{colors.error.default.hex}}",
        "conflict.background": "{{colors.error_container.default.hex}}",
        "created": "{{colors.tertiary.default.hex}}",
        "created.background": "{{colors.tertiary_container.default.hex}}",
        "deleted": "{{colors.error.default.hex}}",
        "deleted.background": "{{colors.error_container.default.hex}}",
        "error": "{{colors.error.default.hex}}",
        "error.background": "{{colors.error_container.default.hex}}",
        "hidden": "{{colors.on_surface_variant.default.hex}}",
        "hidden.background": "{{colors.surface_variant.default.hex}}",
        "hint": "{{colors.tertiary.default.hex}}",
        "hint.background": "{{colors.tertiary_container.default.hex}}",
        "ignored": "{{colors.outline.default.hex}}",
        "ignored.background": "{{colors.surface_variant.default.hex}}",
        "info": "{{colors.secondary.default.hex}}",
        "info.background": "{{colors.secondary_container.default.hex}}",
        "modified": "{{colors.secondary.default.hex}}",
        "modified.background": "{{colors.secondary_container.default.hex}}",
        "predictive": "{{colors.on_surface_variant.default.hex}}",
        "predictive.background": "{{colors.surface_variant.default.hex}}",
        "renamed": "{{colors.tertiary.default.hex}}",
        "renamed.background": "{{colors.tertiary_container.default.hex}}",
        "success": "{{colors.tertiary.default.hex}}",
        "success.background": "{{colors.tertiary_container.default.hex}}",
        "unreachable": "{{colors.error.default.hex}}",
        "unreachable.background": "{{colors.error_container.default.hex}}",
        "warning": "{{colors.secondary.default.hex}}",
        "warning.background": "{{colors.secondary_container.default.hex}}",

        "players": [
          {
            "cursor": "{{colors.primary.default.hex}}",
            "background": "{{colors.primary.default.hex}}",
            "selection": "{{colors.primary.default.hex | set_alpha: 0.3}}"
          }
        ],

        "syntax": {
          "attribute": {
            "color": "{{colors.tertiary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "boolean": {
            "color": "{{colors.tertiary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "comment": {
            "color": "{{colors.outline.default.hex}}",
            "font_style": "italic",
            "font_weight": null
          },
          "comment.doc": {
            "color": "{{colors.on_surface_variant.default.hex}}",
            "font_style": "italic",
            "font_weight": null
          },
          "constant": {
            "color": "{{colors.secondary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "constructor": {
            "color": "{{colors.primary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "embedded": {
            "color": "{{colors.on_background.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "emphasis": {
            "color": null,
            "font_style": "italic",
            "font_weight": null
          },
          "emphasis.strong": {
            "color": null,
            "font_style": null,
            "font_weight": 700
          },
          "enum": {
            "color": "{{colors.secondary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "function": {
            "color": "{{colors.primary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "hint": {
            "color": "{{colors.on_surface_variant.default.hex}}",
            "font_style": null,
            "font_weight": 700
          },
          "keyword": {
            "color": "{{colors.secondary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "label": {
            "color": "{{colors.secondary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "link_text": {
            "color": "{{colors.primary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "link_uri": {
            "color": "{{colors.tertiary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "number": {
            "color": "{{colors.tertiary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "operator": {
            "color": "{{colors.on_background.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "predictive": {
            "color": "{{colors.outline.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "preproc": {
            "color": "{{colors.tertiary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "primary": {
            "color": "{{colors.on_background.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "property": {
            "color": "{{colors.on_background.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "punctuation": {
            "color": "{{colors.on_surface_variant.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "punctuation.bracket": {
            "color": "{{colors.on_surface_variant.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "punctuation.delimiter": {
            "color": "{{colors.on_surface_variant.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "punctuation.list_marker": {
            "color": "{{colors.primary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "punctuation.special": {
            "color": "{{colors.secondary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "string": {
            "color": "{{colors.tertiary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "string.escape": {
            "color": "{{colors.secondary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "string.regex": {
            "color": "{{colors.secondary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "string.special": {
            "color": "{{colors.secondary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "string.special.symbol": {
            "color": "{{colors.on_background.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "tag": {
            "color": "{{colors.primary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "text.literal": {
            "color": "{{colors.tertiary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "title": {
            "color": "{{colors.primary.default.hex}}",
            "font_style": null,
            "font_weight": 700
          },
          "type": {
            "color": "{{colors.secondary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "variable": {
            "color": "{{colors.on_background.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "variable.special": {
            "color": "{{colors.primary.default.hex}}",
            "font_style": null,
            "font_weight": null
          },
          "variant": {
            "color": "{{colors.secondary.default.hex}}",
            "font_style": null,
            "font_weight": null
          }
        }
      }
    }
  ]
}
