{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {},
  "theme": {
    "primary": {
      "dark": "{{colors.primary.default.hex}}",
      "light": "{{colors.primary.default.hex}}"
    },
    "secondary": {
      "dark": "{{colors.secondary.default.hex}}",
      "light": "{{colors.secondary.default.hex}}"
    },
    "accent": {
      "dark": "{{colors.tertiary.default.hex}}",
      "light": "{{colors.tertiary.default.hex}}"
    },
    "error": {
      "dark": "{{colors.error.default.hex}}",
      "light": "{{colors.error.default.hex}}"
    },
    "warning": {
      "dark": "{{colors.secondary_fixed_dim.default.hex}}",
      "light": "{{colors.secondary.default.hex}}"
    },
    "success": {
      "dark": "{{colors.tertiary.default.hex}}",
      "light": "{{colors.tertiary.default.hex}}"
    },
    "info": {
      "dark": "{{colors.primary_fixed.default.hex}}",
      "light": "{{colors.primary.default.hex}}"
    },
    "text": {
      "dark": "{{colors.on_surface.default.hex}}",
      "light": "{{colors.on_surface.default.hex}}"
    },
    "textMuted": {
      "dark": "{{colors.outline.default.hex}}",
      "light": "{{colors.outline.default.hex}}"
    },
    "background": {
      "dark": "{{colors.background.default.hex}}",
      "light": "{{colors.surface.default.hex}}"
    },
    "backgroundPanel": {
      "dark": "{{colors.surface_variant.default.hex}}",
      "light": "{{colors.surface_variant.default.hex}}"
    },
    "backgroundElement": {
      "dark": "{{colors.surface.default.hex}}",
      "light": "{{colors.background.default.hex}}"
    },
    "border": {
      "dark": "{{colors.outline.default.hex}}",
      "light": "{{colors.outline.default.hex}}"
    },
    "borderActive": {
      "dark": "{{colors.primary.default.hex}}",
      "light": "{{colors.primary.default.hex}}"
    },
    "borderSubtle": {
      "dark": "{{colors.outline_variant.default.hex}}",
      "light": "{{colors.outline_variant.default.hex}}"
    },
    "diffAdded": {
      "dark": "{{colors.tertiary.default.hex}}",
      "light": "{{colors.tertiary.default.hex}}"
    },
    "diffRemoved": {
      "dark": "{{colors.error.default.hex}}",
      "light": "{{colors.error.default.hex}}"
    },
    "diffContext": {
      "dark": "{{colors.outline.default.hex}}",
      "light": "{{colors.outline.default.hex}}"
    },
    "syntaxComment": {
      "dark": "{{colors.outline.default.hex}}",
      "light": "{{colors.outline.default.hex}}"
    },
    "syntaxKeyword": {
      "dark": "{{colors.primary.default.hex}}",
      "light": "{{colors.primary.default.hex}}"
    },
    "syntaxFunction": {
      "dark": "{{colors.secondary.default.hex}}",
      "light": "{{colors.secondary.default.hex}}"
    },
    "syntaxVariable": {
      "dark": "{{colors.on_surface.default.hex}}",
      "light": "{{colors.on_surface.default.hex}}"
    },
    "syntaxString": {
      "dark": "{{colors.tertiary.default.hex}}",
      "light": "{{colors.tertiary.default.hex}}"
    },
    "syntaxNumber": {
      "dark": "{{colors.tertiary_fixed_dim.default.hex}}",
      "light": "{{colors.tertiary.default.hex}}"
    },
    "syntaxType": {
      "dark": "{{colors.primary_fixed.default.hex}}",
      "light": "{{colors.primary.default.hex}}"
    },
    "syntaxOperator": {
      "dark": "{{colors.on_surface.default.hex}}",
      "light": "{{colors.on_surface.default.hex}}"
    }
  }
}